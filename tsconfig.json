{
  "compilerOptions": {
    /* Basic Options */
    "target": "ES2020",
    "module": "CommonJS",          
    "moduleResolution": "Node",   
    "rootDir": "./src",             
    "outDir": "./dist",             
    
    /* Type Checking */
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "esModuleInterop": true,      
    
    /* Experimental Options */
    "verbatimModuleSyntax": false, 
    "sourceMap": true,
    "declaration": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],          
  "exclude": ["node_modules"]
}














